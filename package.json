{
  "name": "agent-interview-knowledge-brain",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "build:pages": "tsc -b && vite build --base=/for-work/",
    "preview": "vite preview --host 127.0.0.1",
    "validate:data": "tsx scripts/validate-data.mjs",
    "validate:graph": "tsx scripts/validate-graph.mjs",
    "validate:content-depth": "tsx scripts/validate-content-depth.mjs",
    "generate:markdown-content": "tsx scripts/generate-markdown-content.mjs",
    "validate:markdown-content": "tsx scripts/validate-markdown-content.mjs",
    "validate:content-quality": "tsx scripts/validate-content-quality.mjs",
    "audit:technical-depth": "tsx scripts/audit-technical-depth.mjs",
    "audit:content-rigor": "tsx scripts/audit-content-rigor.mjs",
    "audit:publication-readiness": "tsx scripts/audit-publication-readiness.mjs --write-report",
    "audit:publication-readiness:strict": "tsx scripts/audit-publication-readiness.mjs --write-report --strict",
    "audit:coverage-map": "tsx scripts/audit-coverage-map.mjs",
    "validate:interview-ui": "tsx scripts/validate-interview-ui-contract.mjs",
    "validate:all": "npm run validate:data && npm run validate:graph && npm run validate:content-depth && npm run validate:markdown-content && npm run validate:content-quality && npm run validate:interview-ui"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "lucide-react": "^0.468.0",
    "mermaid": "^11.16.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^6.0.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
